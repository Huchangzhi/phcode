{
  "name": "@phoi/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "bin": "dist/main.js",
  "scripts": {
    "dev": "npm -w @phoi/frontend run build && tsx watch src/main.ts",
    "build": "tsc -b",
    "start": "node dist/main.js",
    "package": "pkg dist/main.js --output phcode.exe --fallback-to-source --public",
    "clean": "node -e \"import('fs').then(({rmSync})=>rmSync('dist',{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@phoi/shared": "*",
    "express": "^4.19.0",
    "cors": "^2.8.5"
  },
  "pkg": {
    "assets": ["dist/**/*.js"]
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.0",
    "@yao-pkg/pkg": "^6.21.0",
    "typescript": "^5.5.0"
  }
}
